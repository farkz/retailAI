{
  "name": "RETAIL",
  "version": "1.0.0",
  "description": "Phase 1 Setup Tests (TypeScript + Playwright)",
  "main": "index.js",
  "scripts": {
    "test:phase1": "mocha tests/phase1-setup/phase1-complete.spec.ts --require ts-node/register --timeout 180000",
    "test": "mocha tests/**/*.spec.ts --require ts-node/register --timeout 120000",
    "test:login": "mocha tests/phase1-setup/login.spec.ts --require ts-node/register",
    "clean": "rimraf node_modules package-lock.json && npm install",
    "build": "tsc"
  },
  "dependencies": {
    "chai": "^5.1.1",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@types/chai": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "mocha": "^10.7.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "mocha": {
    "extension": ["ts"],
    "require": ["ts-node/register"],
    "timeout": 180000
  },
  "keywords": [
    "testing",
    "playwright",
    "mocha",
    "typescript",
    "betting",
    "retail"
  ],
  "author": "",
  "license": "ISC"
}