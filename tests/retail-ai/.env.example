# Copy this file to .env and fill in your values
# cp .env.example .env

# The base URL of the retail API (no trailing slash)
BASE_URL=https://your-api-domain.com

# Tenant ID for the environment you are targeting
TENANT_ID=your-tenant-id

# Back-office admin credentials
BO_USERNAME=your-bo-username
BO_PASSWORD=your-bo-password

# PostgreSQL connection string for DB verification
DATABASE_URL=postgresql://user:password@host:5432/dbname
