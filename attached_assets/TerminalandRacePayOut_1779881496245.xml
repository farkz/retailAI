    def ticketId = row.'TICKET.ID'?.text()?.trim()
    if (ticketId) {
        ticketIds &lt;&lt; ticketId
    }
}

log.info("Extracted ${ticketIds.size()} ticket IDs")

// ====================== SAVE TO PROPERTIES TEST STEP ======================
if (ticketIds) {
    String idsCommaSeparated = ticketIds.join(",")
    
    def propertiesStep = testRunner.testCase.getTestStepByName("Properties")
    
    if (propertiesStep) {
        // Save to the Properties test step
        propertiesStep.setPropertyValue("WonTicketIds", idsCommaSeparated)
        propertiesStep.setPropertyValue("WonTicketCount", ticketIds.size().toString())
        
        log.info("✅ Successfully saved to Properties step:")
        log.info("   • WonTicketIds     = ${idsCommaSeparated}")
        log.info("   • WonTicketCount   = ${ticketIds.size()}")
    } else {
        log.error("Properties test step named 'Properties' not found!")
        // Fallback: save to TestCase properties
        testRunner.testCase.setPropertyValue("WonTicketIds", idsCommaSeparated)
        testRunner.testCase.setPropertyValue("WonTicketCount", ticketIds.size().toString())
        testRunner.testCase.setProperty("wonTicketIdsList", ticketIds)
    }
    //context.setProperty("wonTicketIdsList", ticketIds)
    
} else {
    log.warn("No ticket IDs found")
}</script></con:config></con:testStep><con:testStep type="delay" name="Delay" id="966343ee-af90-4571-b1bc-684a5ab215e5"><con:settings/><con:config><delay>1000</delay></con:config></con:testStep><con:testStep type="restrequest" name="BO_checkWonTickets" id="fde0b0c6-606a-4b6b-83fa-edb499e0222a" disabled="true"><con:settings/><con:config service="X.VirtualRace.IntegrationApi" resourcePath="/api/public/Ticket/GetTicketsOverview" methodName="POST" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"><con:restRequest name="BO_checkWonTickets" id="629a9b92-b070-46be-a4e8-b2e03cb99cbe" mediaType="application/json" postQueryString="false"><con:settings><con:setting id="com.eviware.soapui.impl.wsdl.WsdlRequest@request-headers">&lt;entry key="Authorization" value="${UserBO}" xmlns="http://eviware.com/soapui/config"/></con:setting></con:settings><con:endpoint>${virtualrace}</con:endpoint><con:request>{
