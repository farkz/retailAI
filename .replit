modules = ["nodejs-20", "python-3.11"]

[[ports]]
localPort = 3099
externalPort = 3002

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 20130
externalPort = 3000

[userenv]

[userenv.shared]
BASE_URL = "https://retailapi.stage-xtreme.com"
TENANT_ID = "679a5ac9-d5da-4c9e-9dd2-dcf2eb07cdbc"
NODE_ENV = "development"

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[workflows]
runButton = "Project"
