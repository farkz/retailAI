{
  "name": "RETAIL",
  "version": "1.0.0",
  "description": "Phase 1 Setup Tests (TypeScript + Playwright)",
  "main": "index.js",
  "scripts": {
    "test:phase1": "mocha tests/phase1-setup/phase1-complete.spec.ts --require ts-node/register --timeout 180000",
    "test:phase2": "mocha tests/phase2-race-payin/phase2-complete.spec.ts --require ts-node/register --timeout 300000",
    "test:phase3": "mocha tests/phase3-race-payout/phase3-complete.spec.ts --require ts-node/register --timeout 600000",
    "test:phase4": "mocha tests/phase4-bingo-payin/phase4-complete.spec.ts --require ts-node/register --timeout 600000",
    "test": "mocha tests/**/*.spec.ts --require ts-node/register --timeout 120000",
    "test:login": "mocha tests/phase1-setup/login.spec.ts --require ts-node/register",
    "clean": "rimraf node_modules package-lock.json && npm install",
    "build": "tsc",
    "cleanup:staging": "ts-node scripts/cleanupStaging.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "chai": "^5.3.3",
    "dotenv": "^16.6.1",
    "pg": "^8.21.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.20.0",
    "mocha": "^10.8.2",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "mocha": {
    "extension": [
      "ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "timeout": 180000
  },
  "keywords": [
    "testing",
    "playwright",
    "mocha",
    "typescript",
    "betting",
    "retail"
  ],
  "author": "",
  "license": "ISC"
}
