import java.util.Random

def generateUUIDv7() {
    long timestamp = System.currentTimeMillis()
    long mostSigBits = (timestamp << 16) & 0xFFFFFFFFFFFF0000L
    mostSigBits |= (0x7L << 12)
    Random random = new Random()
    long leastSigBits = random.nextLong() & 0xFFFFFFFFFFFF0FFFL
    UUID uuidv7 = new UUID(mostSigBits, leastSigBits)
    return uuidv7.toString()
}

return generateUUIDv7()]]></script></con:config></con:testStep><con:testStep type="groovy" name="Datetime" id="40494f20-c9c5-4761-a809-d3dc431f8e53"><con:settings/><con:config><script>import groovy.time.TimeCategory

