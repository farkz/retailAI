import java.util.Random

def generateUUIDv7() {
    long timestamp = System.currentTimeMillis()
    long mostSigBits = (timestamp << 16) & 0xFFFFFFFFFFFF0000L
    mostSigBits |= (0x7L << 12)
    Random random = new Random()
    long leastSigBits = random.nextLong() & 0xFFFFFFFFFFFF0FFFL
    UUID uuidv7 = new UUID(mostSigBits, leastSigBits)
    return uuidv7.toString()
}

return generateUUIDv7()]]></script></con:config></con:testStep><con:testStep type="restrequest" name="PayOut" id="40619245-62db-4078-b206-989560dab486"><con:settings/><con:config service="X.VirtualRace.IntegrationApi" resourcePath="/api/public/Ticket/PayOut" methodName="POST" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"><con:restRequest name="PayOut" id="16daada8-6443-4714-94a4-877d446ef4de" mediaType="application/json" postQueryString="false"><con:settings><con:setting id="com.eviware.soapui.impl.wsdl.WsdlRequest@request-headers">&lt;entry key="Authorization" value="${Properties#TerminalToken}" xmlns="http://eviware.com/soapui/config"/></con:setting></con:settings><con:endpoint>${virtualraceintegration}</con:endpoint><con:request>{
